		"eslint-plugin-obsidianmd": "^0.2.4",
		"globals": "^17.5.0",
		"jiti": "^2.6.1",
		"jsdom": "^29.0.2",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
